{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -B \"{{CODEX_HOOKS_DIR}}/session-start-context.py\"",
            "statusMessage": "Loading session mode context",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -B \"{{CODEX_HOOKS_DIR}}/hook-security-context-hook.py\"",
            "statusMessage": "Checking mode-gated offensive routing",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
